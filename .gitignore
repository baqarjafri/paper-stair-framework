# ==============================================================================
# LOCAL-ONLY FILES — present in the working directory, excluded from the public
# GitHub repo. The repository's job is to let readers reproduce the paper's
# quantitative findings from the Moodle source; it is NOT a document-production
# pipeline. The files below are needed locally to build the paper itself but
# reveal nothing that serves the reproducibility audience, so they stay off
# GitHub while remaining intact on disk.
# ==============================================================================

# Paper-build pipeline (local-only — produces the PDF we ship in paper/)
build_conference_docx.js
build_conference_html.js
build_pdf.js
ai_detection_heuristic.py

# Paper source (the compiled PDF in paper/ is the canonical artefact)
sections/
references.md
references_verified/

# Figure sources (rendered PNGs ship in figures/)
figures_src/

# Title-page icon asset (used at build time; embedded into the PDF we ship;
# not needed in the public repo since the docx/HTML builders are local-only)
figures/github_icon.png

# Vestigial figure-generation script (writes to ../task5/ from a parent layout)
analysis/code/generate_figures.py

# ==============================================================================
# Audit reports (auto-generated log file with timestamps; local-only)
# ==============================================================================
docs/AUDIT_REPORT.md

# ==============================================================================
# Compiled paper artefacts (regenerable locally; never committed)
# ==============================================================================
Paper_1_STAIR_AITHE2026.docx
Paper_1_STAIR_AITHE2026.html
~$*.docx

# ==============================================================================
# Moodle source (fetched at reproduction time via scripts/fetch_moodle.*)
# ==============================================================================
moodle_src/

# ==============================================================================
# Reproduction outputs (regenerated by reproduce.py)
# ==============================================================================
analysis/outputs/

